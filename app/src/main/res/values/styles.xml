<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.CALCY.Button" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.CALCY.Card" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Widget.CALCY.Button.Base" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CALCY.Button</item>
        <item name="strokeWidth">0dp</item>
        <item name="elevation">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
    </style>

    <style name="Widget.CALCY.Button.Number" parent="Widget.CALCY.Button.Base">
        <item name="backgroundTint">@color/calcy_btn_number_bg</item>
        <item name="android:textColor">@color/calcy_btn_number_text</item>
    </style>

    <style name="Widget.CALCY.Button.Operator" parent="Widget.CALCY.Button.Base">
        <item name="backgroundTint">@color/calcy_btn_operator_bg</item>
        <item name="android:textColor">@color/calcy_btn_operator_text</item>
    </style>

    <style name="Widget.CALCY.Button.Action" parent="Widget.CALCY.Button.Base">
        <item name="backgroundTint">@color/calcy_btn_action_bg</item>
        <item name="android:textColor">@color/calcy_btn_action_text</item>
    </style>

    <style name="Widget.CALCY.Button.Function" parent="Widget.CALCY.Button.Base">
        <item name="android:textSize">18sp</item>
        <item name="backgroundTint">@color/calcy_btn_function_bg</item>
        <item name="android:textColor">@color/calcy_btn_function_text</item>
    </style>

    <style name="Widget.CALCY.Button.Equal" parent="Widget.CALCY.Button.Base">
        <item name="backgroundTint">@color/calcy_btn_equal_bg</item>
        <item name="android:textColor">@color/calcy_btn_equal_text</item>
    </style>

    <style name="Widget.CALCY.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/calcy_surface</item>
        <item name="cardElevation">3dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CALCY.Card</item>
        <item name="strokeColor">@color/calcy_outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

</resources>
